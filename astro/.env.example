# Porta do servidor
PORT=3000

# Segredo para assinar os tokens de sessão (JWT) — troque por algo longo e aleatório
JWT_SECRET=troque-este-valor-por-uma-string-aleatoria-longa
JWT_EXPIRES_IN=7d

# Banco persistente Postgres/Neon para producao (configure na Vercel)
DATABASE_URL=

# Fallback local SQLite (relativo à raiz do projeto astro/, usado sem DATABASE_URL)
DB_FILE=./data/icl.sqlite

# Administrador inicial, criado apenas na primeira execução
ADMIN_NAME=Administrador Impulsa Ijuí
ADMIN_EMAIL=admin@impulsaijui.com.br
ADMIN_PASSWORD=trocar-no-primeiro-login

# Recuperacao de senha
PASSWORD_RESET_EXPIRES_MINUTES=30
# Sem provedor de e-mail, o link de reset e exibido na tela. Use "false" em producao.
PASSWORD_RESET_SHOW_LINK=true
