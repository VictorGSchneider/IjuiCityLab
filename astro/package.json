{
  "name": "impulsa-ijui",
  "version": "2.0.0",
  "description": "Impulsa Ijui - site, painel ao vivo, portal do participante, administracao e API de dados abertos. Astro SSR + Postgres em producao, SQLite local.",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--experimental-sqlite astro dev",
    "build": "astro build",
    "preview": "NODE_OPTIONS=--experimental-sqlite astro preview",
    "start": "node --experimental-sqlite ./dist/server/entry.mjs",
    "upgrade": "bash scripts/upgrade.sh"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.4",
    "@astrojs/vercel": "^10.0.8",
    "astro": "^6.4.7",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "path-to-regexp": "^8.2.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true
  }
}
