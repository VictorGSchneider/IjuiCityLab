{
  "name": "ijui-city-lab",
  "version": "2.0.0",
  "description": "Ijuí City Lab — site, painel ao vivo, portal do participante, administração e API de dados abertos. Astro SSR + SQLite (node:sqlite, sem dependência nativa).",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--experimental-sqlite astro dev",
    "build": "astro build",
    "preview": "NODE_OPTIONS=--experimental-sqlite astro preview",
    "start": "node --experimental-sqlite ./dist/server/entry.mjs",
    "upgrade": "bash scripts/upgrade.sh"
  },
  "engines": { "node": ">=22.5" },
  "dependencies": {
    "@astrojs/node": "^10.1.4",
    "astro": "^6.4.7",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.2"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
