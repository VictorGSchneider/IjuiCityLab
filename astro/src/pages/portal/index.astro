<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ijuí City Lab — Portal do Participante</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/portal.css" />
</head>
<body>

<header class="topbar" hidden>
  <a class="brand" href="/"><strong>ICL</strong> <span>Portal do participante</span></a>
  <nav class="tabs">
    <button class="tab active" data-view="proposals">Minhas propostas</button>
    <button class="tab" data-view="new">Nova proposta</button>
    <button class="tab" data-view="api">API &amp; Dados</button>
    <button class="tab" data-view="account">Minha conta</button>
  </nav>
  <div class="user">
    <span class="user-name"></span>
    <button class="logout">Sair</button>
  </div>
</header>

<main class="auth-wrap">
  <div class="auth-tabs">
    <button class="auth-tab active" data-mode="login">Entrar</button>
    <button class="auth-tab" data-mode="register">Criar conta</button>
  </div>

  <form class="card auth-card" id="loginForm">
    <h1>Acessar portal</h1>
    <p class="muted">Acompanhe suas propostas e integre seus dados ao Ijuí City Lab.</p>
    <label>E-mail<input type="email" name="email" required autocomplete="username" /></label>
    <label>Senha<input type="password" name="password" required autocomplete="current-password" /></label>
    <button type="submit" class="btn primary">Entrar</button>
    <p class="feedback" role="status" aria-live="polite"></p>
  </form>

  <form class="card auth-card" id="registerForm" hidden>
    <h1>Criar conta</h1>
    <p class="muted">Cadastre-se para submeter projetos e enviar dados ao sandbox.</p>
    <label>Nome completo<input type="text" name="name" required autocomplete="name" /></label>
    <label>E-mail<input type="email" name="email" required autocomplete="email" /></label>
    <label>Empresa ou organização<input type="text" name="company" autocomplete="organization" /></label>
    <label>CNPJ (opcional)<input type="text" name="cnpj" /></label>
    <label>Telefone (opcional)<input type="tel" name="phone" autocomplete="tel" /></label>
    <label>Senha (mínimo 8 caracteres)<input type="password" name="password" minlength="8" required autocomplete="new-password" /></label>
    <button type="submit" class="btn primary">Criar conta</button>
    <p class="feedback" role="status" aria-live="polite"></p>
  </form>
</main>

<main class="app-wrap" hidden>

  <section class="view" data-view="proposals">
    <div class="view-head">
      <h2>Minhas propostas</h2>
      <button class="btn primary" data-go="new">Nova proposta</button>
    </div>
    <div class="table-wrap"><table id="proposalsTable"><thead><tr>
      <th>#</th><th>Proponente</th><th>Área</th><th>Estágio</th><th>Status</th><th>Atualização</th><th></th>
    </tr></thead><tbody></tbody></table></div>
  </section>

  <section class="view" data-view="new" hidden>
    <h2>Nova proposta</h2>
    <p class="muted">Os dados de contato vêm do seu cadastro — ajuste se quiser para esta proposta.</p>
    <form id="proposalForm" class="card form-card">
      <div class="row">
        <label>Seu nome<input type="text" name="nome" required /></label>
        <label>Seu e-mail<input type="email" name="email" required /></label>
      </div>
      <div class="row">
        <label>Empresa ou proponente<input type="text" name="proponente" required /></label>
        <label>CNPJ (opcional)<input type="text" name="cnpj" /></label>
      </div>
      <div class="row">
        <label>Perfil do proponente
          <select name="perfil" required>
            <option value="" disabled selected>Selecione</option>
            <option value="startup">Startup</option>
            <option value="empresa">Empresa estabelecida</option>
            <option value="pesquisador">Pesquisador / academia</option>
            <option value="estudante">Estudante</option>
            <option value="poder-publico">Poder público</option>
            <option value="outro">Outro</option>
          </select>
        </label>
        <label>Área de interesse
          <select name="area" required>
            <option value="" disabled selected>Selecione</option>
            <option value="mobilidade">Mobilidade urbana</option>
            <option value="energia">Energia inteligente</option>
            <option value="saude">Saúde e bem-estar</option>
            <option value="seguranca">Segurança pública</option>
            <option value="dados">Dados e IoT</option>
            <option value="outro">Outro</option>
          </select>
        </label>
      </div>
      <label>Estágio da solução
        <select name="estagio" required>
          <option value="" disabled selected>Selecione</option>
          <option value="ideia">Ideia / conceito</option>
          <option value="prototipo">Protótipo</option>
          <option value="piloto">Piloto</option>
          <option value="escala">Pronto para escala</option>
        </select>
      </label>
      <label>Objetivo do teste na sandbox<input type="text" name="objetivo" required /></label>
      <label>Resumo (mín. 20 caracteres)<textarea name="resumo" minlength="20" required></textarea></label>
      <button type="submit" class="btn primary">Enviar proposta</button>
      <p class="feedback" role="status" aria-live="polite"></p>
    </form>
  </section>

  <section class="view" data-view="api" hidden>
    <h2>API &amp; Dados</h2>
    <p class="muted">Gere chaves para enviar automaticamente os dados das suas soluções e para ler a base aberta do Lab. A chave aparece <strong>uma única vez</strong> — guarde com segurança.</p>

    <div class="card form-card">
      <h3>Meus projetos no sandbox</h3>
      <p class="muted">Projetos são criados e atribuídos pela equipe do Lab a partir das propostas aprovadas. Use o <code>slug</code> ao enviar dados.</p>
      <div class="table-wrap"><table id="myProjectsTable"><thead><tr>
        <th>Projeto</th><th>Slug</th><th>Área</th><th>Status</th><th>Dados</th>
      </tr></thead><tbody></tbody></table></div>
    </div>

    <form id="keyForm" class="card form-card">
      <h3>Gerar nova chave de API</h3>
      <div class="row">
        <label>Nome / referência<input type="text" name="name" placeholder="Ex.: sensor-ar-rasp01" required /></label>
        <label>Permissão
          <select name="scope">
            <option value="read_ingest">Ler e enviar</option>
            <option value="ingest">Apenas enviar</option>
            <option value="read">Apenas ler</option>
          </select>
        </label>
      </div>
      <button type="submit" class="btn primary">Gerar chave</button>
      <p class="feedback" role="status" aria-live="polite"></p>
      <div id="newKeyBox" class="key-box" hidden>
        <strong>Sua nova chave (copie agora):</strong>
        <code id="newKeyValue"></code>
      </div>
    </form>

    <div class="card form-card">
      <h3>Minhas chaves</h3>
      <div class="table-wrap"><table id="keysTable"><thead><tr>
        <th>Nome</th><th>Prefixo</th><th>Permissão</th><th>Último uso</th><th>Status</th><th></th>
      </tr></thead><tbody></tbody></table></div>
    </div>

    <div class="card form-card">
      <h3>Como enviar dados</h3>
      <p class="muted">Endpoint de ingestão (precisa de chave com permissão de envio):</p>
      <pre class="code-block" id="ingestExample"></pre>
      <p class="muted">Documentação completa e leitura da base aberta em <a href="/docs/api">/docs/api</a>.</p>
    </div>
  </section>

  <section class="view" data-view="account" hidden>
    <h2>Minha conta</h2>
    <form id="accountForm" class="card form-card">
      <div class="row">
        <label>Nome<input type="text" name="name" required /></label>
        <label>E-mail<input type="email" name="email" disabled /></label>
      </div>
      <div class="row">
        <label>Empresa<input type="text" name="company" /></label>
        <label>CNPJ<input type="text" name="cnpj" /></label>
      </div>
      <label>Telefone<input type="tel" name="phone" /></label>
      <button type="submit" class="btn primary">Salvar alterações</button>
      <p class="feedback" role="status" aria-live="polite"></p>
    </form>
    <form id="passwordForm" class="card form-card">
      <h3>Alterar senha</h3>
      <label>Senha atual<input type="password" name="current" required /></label>
      <label>Nova senha (mínimo 8 caracteres)<input type="password" name="next" minlength="8" required /></label>
      <button type="submit" class="btn">Atualizar senha</button>
      <p class="feedback" role="status" aria-live="polite"></p>
    </form>
  </section>
</main>

<dialog id="detailDialog">
  <article id="detailContent"></article>
  <form method="dialog"><button class="btn">Fechar</button></form>
</dialog>

<script src="/portal.js" is:inline></script>
</body>
</html>
